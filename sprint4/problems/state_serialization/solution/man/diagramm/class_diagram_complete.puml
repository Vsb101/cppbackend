package "logger" {
    
    class Logger {
        <<namespace>>
        + InitLogger()
        + LogInfo(msg: string_view)
        + LogInfo<T>(msg: string_view, data: T)
        + LogError(msg: string_view)
        + LogError<T>(msg: string_view, data: T)
        + LogWarning(msg: string_view)
