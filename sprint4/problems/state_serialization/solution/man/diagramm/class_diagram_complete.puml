' ============================================================================
' ОТНОШЕНИЯ И СВЯЗИ
' ============================================================================

' --- Main relationships ---
Program --> Application : creates & configures
Program --> JsonLoader : loads config
Program --> SerializingListener : creates (if state file)
Program --> RequestHandler : passes to HTTP server
Program --> Logger : initializes
Program --> Listener : starts HTTP server

' --- Application relationships ---
Application o-- Game : contains
Application o-- PlayerTokens : contains
Application o-- ExtraData : contains
Application --> Player : manages
Application --> StateListener : notifies
Application --> Logger : logs

' --- Player relationships ---
Player --> GameSession : belongs to (weak)
Player --> Dog : controls (weak)
PlayerTokens --> Player : maps token ->

' --- Game relationships ---
Game o-- GameSession : aggregates
Game --> Map : contains

' --- GameSession relationships ---
GameSession o-- Map : owns
GameSession *-- Dog : owns many
GameSession o-- LootGenerator : uses
GameSession *-- LostObject : owns many
GameSession --> CollisionDetector : uses
GameSession --> Logger : logs

' --- Map relationships ---
Map *-- Road : contains
Map *-- Building : contains
Map *-- Office : contains
Map --> geom : uses types

' --- Dog relationships ---
Dog *-- Dog::BagItem : contains
Dog --> Direction : uses
Dog --> Point2D : position
Dog --> Vec2D : speed

' --- SerializingListener relationships ---
StateListener <|-- SerializingListener : extends
SerializingListener --> ApplicationState : captures
ApplicationState o-- SessionData : contains
ApplicationState o-- PlayerData : contains
SerializingListener --> Logger : logs errors

' --- HTTP relationships ---
RequestHandler o-- ApiHandler : delegates API
RequestHandler o-- Application : uses
Listener <creates> Session
Session <extends> SessionBase
Session --> RequestHandler : uses
SessionBase --> Logger : logs

' --- API relationships ---
ApiHandler o-- Application : uses
ApiHandler --> JsonSerialization : serializes
ApiHandler --> Endpoints : routes
JsonSerialization --> Dog : serializes
JsonSerialization --> Map : serializes
JsonSerialization --> Player : serializes

' --- JSON Loader relationships ---
JsonLoader --> ProjectConfig : creates
JsonLoader --> JsonSerialization : deserializes
JsonLoader --> Logger : logs errors

' --- Util relationships ---
Tagged --> Player::Id : used by
Tagged --> Dog::Id : used by
Tagged --> GameSession::Id : used by
Tagged --> Map::Id : used by
Tagged --> Office::Id : used by
Tagged --> LostObject::Id : used by
Tagged --> PlayerTokens : used by
TaggedHasher --> Tagged : hashes

' --- Logger relationships ---
Logger --> RequestLog : uses
Logger --> ResponseLog : uses
Logger --> ServerAddrPortLog : uses
Logger --> ExceptionLog : uses
Logger --> ExitCodeLog : uses

' --- Dependencies ---
SessionBase --> boost::asio : uses
SessionBase --> boost::beast : uses
SerializingListener --> boost::serialization : uses
JsonLoader --> boost::json : uses
Program --> boost::program_options : parses args

' ============================================================================
' КОМПОЗИЦИЯ И АГРЕГАЦИЯ (ДЕТАЛИЗАЦИЯ)
' ============================================================================

' Composition (filled diamond - strong ownership)
Map *-- "0..*" Road : roads
Map *-- "0..*" Building : buildings
Map *-- "0..*" Office : offices
GameSession *-- "0..*" Dog : dogs
GameSession *-- "0..*" LostObject : lost_objects
Dog *-- "0..*" BagItem : bag
ApplicationState *-- "0..*" SessionData : sessions
ApplicationState *-- "0..*" PlayerData : players

' Aggregation (empty diamond - weak ownership)
Game o-- "0..*" GameSession : sessions
Application o-- "1" Game : game
Application o-- "1" PlayerTokens : tokens
Application o-- "1" ExtraData : extra_data
GameSession o-- "1" LootGenerator : generator
SerializingListener o-- "1" Application : app

' Association (line - usage relationship)
Player -- GameSession : session
Player -- Dog : dog
RequestHandler -- Application : application
ApiHandler -- Application : application
JsonLoader -- Game : game
JsonLoader -- ExtraData : extra_data

' ============================================================================
' НАСЛЕДОВАНИЕ
' ============================================================================

StateListener <|-- SerializingListener
SessionBase <|-- Session<RequestHandler>

