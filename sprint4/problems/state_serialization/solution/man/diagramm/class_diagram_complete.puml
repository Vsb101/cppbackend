' ============================================================================
' ИНФРАСТРУКТУРА - СЕРВЕРОЕ И СЕРИАЛИЗАЦИЯ (INFRA LAYER)
' ============================================================================

package "infra" {
    
    ' --- Интерфейс слушателя ---
    class StateListener <<interface>> {
        <<abstract>>
        # StateListener()
        + OnTick(delta: milliseconds): void {abstract}
        + OnShutdown(): void {abstract}
    }
    
    ' --- Сериализация состояния ---
    class SerializingListener {
        - state_file_path_: filesystem::path
        - save_period_: milliseconds
        - app_: Application*
        - time_since_save_: milliseconds
        + SerializingListener(path: filesystem::path, period: milliseconds, app: Application*)
        + LoadState(): bool
        + SaveState(): void
        + OnTick(delta: milliseconds): void
        + OnShutdown(): void
        - DoSaveState(): void
        - CaptureState(): ApplicationState
        - RestoreState(state: ApplicationState): void
    }
    
    class ApplicationState {
        + sessions: vector<SessionData>
        + players: vector<PlayerData>
        + next_player_id: size_t
    }
    
    class ApplicationState::SessionData {
        - map_id: string
        - dogs: vector<Dog>
        - lost_objects: unordered_map<uint32_t, LostObject>
        - next_dog_id: uint32_t
        - next_loot_id: uint32_t
    }
    
    class ApplicationState::PlayerData {
        - token: string
        - player_id: size_t
        - player_name: string
        - map_id: string
        - dog_id: size_t
    }
    
    ' --- HTTP сервер ---
    class HttpServer {
        <<namespace>>
        + ServeHttp(ioc: io_context, endpoint: tcp_endpoint, handler: RequestHandler)
        + ErrorMessage(ec: beast::error_code, what: string_view)
    }
    
    class SessionBase {
        - stream_: beast::tcp_stream
        - buffer_: beast::flat_buffer
        - request_: HttpRequest
        - req_recieve_time_: ptime
        + SessionBase(socket: tcp::socket)
        + Run(): void
        + GetRemoteIp(): string
        + Write(response: http_response): void
        + SetReqRecieveTime(time: ptime)
        + GetDurReceivedRequest(time: ptime): int32_t
        - Read(): void
        - OnRead(ec: beast::error_code, bytes_read: size_t)
        - OnWrite(close: bool, ec: beast::error_code, bytes_written: size_t)
        - Close(): void
        # HandleRequest(request: HttpRequest): void {abstract}
        # GetSharedThis(): shared_ptr<SessionBase> {abstract}
    }
    
    class Session<RequestHandler> {
        - request_handler_: RequestHandler
        + Session(socket: tcp::socket, handler: RequestHandler)
        + HandleRequest(request: HttpRequest): void
        + GetSharedThis(): shared_ptr<SessionBase>
    }
    
    class Listener<RequestHandler> {
        - ioc_: io_context
        - acceptor_: tcp::acceptor
        - request_handler_: RequestHandler
        + Listener(ioc: io_context, endpoint: tcp_endpoint, handler: RequestHandler)
        + Run(): void
        - DoAccept(): void
        - OnAccept(ec: sys::error_code, socket: tcp::socket)
        - AsyncRunSession(socket: tcp::socket)
    }
    
    ' --- JSON загрузчик ---
    class JsonLoader {
        <<namespace>>
        + LoadGame(path: filesystem::path): ProjectConfig
    }
    
    class ProjectConfig {
        + game: Game
        + extra_data: ExtraData
    }
}

