' ============================================================================
' МОДЕЛЬ - ИГРОВОЙ МИР (MODEL LAYER)
' ============================================================================

package "model" {
    
    ' --- Геймдизайн и типы ---
    class Coord <<type alias>>
    class Dimension <<type alias>>
    
    ' --- Карта и её компоненты ---
    class Map {
        + Id: Tagged<string, Map>
        + name_: string
        + roads_: deque<Road>
        + buildings_: vector<Building>
        + offices_: vector<Office>
        + dog_speed_: double
        + bag_capacity_: size_t
        + loot_types_count_: size_t
        + loot_type_values_: vector<int>
        + GetId(): Id
        + GetName(): string
        + GetRoads(): const deque<Road>&
        + GetBuildings(): const vector<Building>&
        + GetOffices(): const vector<Office>&
        + AddRoad(road: Road)
        + AddBuilding(building: Building)
        + AddOffice(office: Office)
        + SetDogSpeed(speed: double)
        + GetDogSpeed(): double
        + SetBagCapacity(capacity: size_t)
        + GetBagCapacity(): size_t
        + SetLootTypesCount(count: size_t)
        + GetLootTypesCount(): size_t
        + SetLootTypeValue(type: size_t, value: int)
        + GetLootTypeValue(type: size_t): int
    }
    
    class Road {
        + HORIZONTAL: HorizontalTag
        + VERTICAL: VerticalTag
        + start_: Point2D
        + end_: Point2D
        + IsHorizontal(): bool
        + IsVertical(): bool
        + GetStart(): Point2D
        + GetEnd(): Point2D
    }
    
    class Building {
        + bounds_: Rectangle
        + GetBounds(): const Rectangle&
    }
    
    class Office {
        + Id: Tagged<string, Office>
        + id_: Id
        + position_: Point2D
        + offset_: Offset
        + GetId(): Id
        + GetPosition(): Point2D
        + GetOffset(): Offset
    }
    
    ' --- Игровые сессии ---
    class Game {
        + sessions_: unordered_map<Id, shared_ptr<GameSession>>
        + FindOrCreateSession(map_id: Map::Id): shared_ptr<GameSession>
        + GetSessions(): const unordered_map<Id, shared_ptr<GameSession>>&
        + AddMap(map: Map)
    }
    
    class GameSession {
        + Id: Tagged<string, GameSession>
        + map_: shared_ptr<Map>
        + id_: Id
        + dogs_: vector<shared_ptr<Dog>>
        + next_dog_id_: uint32_t
        + loot_generator_: LootGenerator
        + lost_objects_: unordered_map<uint32_t, LostObject>
        + next_loot_id_: uint32_t
        + mutex_: mutex
        + CreateDog(name: string, randomize: bool): shared_ptr<Dog>
        + Update(dt: double)
        + GetMap(): shared_ptr<Map>
        + GetId(): const Id&
        + GetDogs(): const vector<shared_ptr<Dog>>&
        + GetLostObjects(): const unordered_map<uint32_t, LostObject>&
        + SetNextDogId(id: uint32_t)
        + SetNextLootId(id: uint32_t)
        + GetNextDogId(): uint32_t
        + GetNextLootId(): uint32_t
        + RestoreDogs(dogs: vector<Dog>, next_id: uint32_t)
        + RestoreLostObjects(objects: unordered_map<uint32_t, LostObject>, next_id: uint32_t)
    }
    
    ' --- Игровые сущности ---
    class Dog {
        + Id: Tagged<size_t, Dog>
        + BagItem: class
        + id_: Id
        + name_: string
        + direction_: Direction
        + position_: Point2D
        + speed_: Vec2D
        + bag_: vector<BagItem>
        + bag_capacity_: size_t
        + score_: int
        + GetId(): Id
        + GetName(): string
        + GetDirection(): Direction
        + SetDirection(dir: Direction)
        + GetPosition(): Point2D
        + SetPosition(pos: Point2D)
        + GetSpeed(): Vec2D
        + SetSpeed(speed: Vec2D)
        + GetBag(): const vector<BagItem>&
        + GetBagCapacity(): size_t
        + IsBagFull(): bool
        + AddToBag(item_id: uint32_t, type: size_t): bool
        + ClearBag(): vector<BagItem>
        + AddScore(points: int)
        + GetScore(): int
    }
    
    class Dog::BagItem {
        - id: uint32_t
        - type: size_t
        + BagItem()
        + BagItem(item_id: uint32_t, item_type: size_t)
    }
    
    class LostObject {
        + Id: Tagged<uint32_t, LostObject>
        - id: Id
        - type: size_t
        - pos: pair<double, double>
        - collected: bool
    }
    
    ' --- Генератор луута ---
    class LootGenerator {
        + RandomGenerator: type
        + TimeInterval: type
        - base_interval_: TimeInterval
        - probability_: double
        - time_without_loot_: TimeInterval
        - random_generator_: RandomGenerator
        + LootGenerator(base_interval: TimeInterval, probability: double)
        + SetConfig(interval: TimeInterval, probability: double)
        + Generate(delta: TimeInterval, loot_count: unsigned, looter_count: unsigned): unsigned
    }
    
    ' --- Детектор коллизий ---
    class CollisionDetector {
        + IsColliding(dog: Dog, delta: double): bool
        + HandleCollisions(session: GameSession)
        + CheckRoadCollision(dog: Dog, road: Road): bool
        + CheckBuildingCollision(dog: Dog, building: Building): bool
    }
}

