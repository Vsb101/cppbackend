package "api" {
    
    class ApiHandler {
        - application_: Application&
        + ApiHandler(application: Application&)
        + operator()(req: http_request, send: function): void
        - HandleJoin(req, send)
        - HandleMove(req, send)
        - HandleStatus(req, send)
        - HandleDogs(req, send)
    }
    
    class Endpoints {
        <<namespace>>
        + JOIN_ENDPOINT: string_view
        + MOVE_ENDPOINT: string_view
        + STATUS_ENDPOINT: string_view
        + DOGS_ENDPOINT: string_view
    }
    
    class JsonSerialization {
        <<namespace>>
        + tag_invoke(value_from, jv, Dog)
        + tag_invoke(value_from, jv, Player)
        + tag_invoke(value_from, jv, LostObject)
        + tag_invoke(value_from, jv, BagItem)
        + tag_invoke(value_from, jv, Map)
        + tag_invoke(value_from, jv, Road)
        + tag_invoke(value_from, jv, Building)
        + tag_invoke(value_from, jv, Office)
        + tag_invoke(value_to<Road>, jv): Road
        + tag_invoke(value_to<Building>, jv): Building
        + tag_invoke(value_to<Office>, jv): Office
        + tag_invoke(value_to<Map>, jv): Map
    }
}

