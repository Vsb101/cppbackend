package "util" {
    class Tagged<Value, Tag> <<Type-Safe Wrapper>> {
        + ValueType: type
        + TagType: type
        + value_: Value
        + Tagged(v: Value)
        + GetValue(): const Value&
        + operator*(): const Value&
        + operator<=>(const Tagged&): auto
    }
    
    class TaggedHasher<TaggedValue> <<Hash Function>> {
        + operator()(const TaggedValue&): size_t
    }
}

package "geom" {
    class Vec2D {
        + x: double
        + y: double
        + Vec2D(x: double, y: double)
        + operator*=(scale: double): Vec2D&
        + operator<=>(const Vec2D&): auto
    }
    
    class Point2D {
        + x: double
        + y: double
        + Point2D(x: double, y: double)
        + operator+=(v: Vec2D): Point2D&
        + operator<=>(const Point2D&): auto
    }
    
    class Rectangle {
        + position: Point2D
        + size: Size
    }
    
    class Size {
        + width: Dimension
        + height: Dimension
    }
    
    class Offset {
        + dx: Dimension
        + dy: Dimension
    }
    
    enum Direction {
        NORTH
        SOUTH
        WEST
        EAST
    }
}

note right of Tagged
  **Type-Safe ID Pattern**
  
  Предотвращает
  случайную подмену
  значений разных типов
  
  Пример:
  PlayerId != DogId
  даже если оба size_t
end note

